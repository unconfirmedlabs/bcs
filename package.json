{
  "name": "@unconfirmed/bcs",
  "version": "0.2.0",
  "sideEffects": false,
  "description": "High-performance BCS (Binary Canonical Serialization) for TypeScript — powered by bcs-zig WASM. Drop-in replacement for @mysten/bcs.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "wasm/bcs.wasm"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:wasm": "bash wasm/build.sh",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unconfirmedlabs/bcs.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "bcs",
    "binary-canonical-serialization",
    "sui",
    "move",
    "wasm",
    "serialization"
  ]
}
